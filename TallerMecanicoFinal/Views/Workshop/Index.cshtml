@model TallerMecanicoFinal.Models.WorkshopDashboardViewModel
@{
    ViewData["Title"] = "Autos del Día";
}

<div class="appointment-page">
    <div class="card border-0 shadow-sm appointment-hero mb-4">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <p class="text-uppercase text-accent fw-semibold mb-1">Flujo del taller</p>
                    <h1 class="h3 mb-2">Autos del Día</h1>
                    <p class="text-muted mb-0">Solo se muestran las citas registradas para la fecha actual. Los cambios de estado se resuelven con modales AJAX.</p>
                </div>
                <form asp-controller="Workshop" asp-action="Index" method="get" class="d-flex flex-column flex-sm-row gap-2 align-items-stretch align-items-sm-end">
                    <div>
                        <label asp-for="MechanicId" class="form-label small text-muted mb-1">Mecánico activo</label>
                        <input name="mechanicId" value="@Model.MechanicId" class="form-control" placeholder="GUID del mecánico" />
                    </div>
                    <div>
                        <input type="hidden" name="isAdmin" value="@Model.IsAdmin" />
                        <button type="submit" class="btn btn-accent">Cargar agenda</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_WorkshopBoard", Model)
</div>

<div class="modal fade" id="workshopModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" id="workshopModalContent"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/workshop.js" asp-append-version="true"></script>
}