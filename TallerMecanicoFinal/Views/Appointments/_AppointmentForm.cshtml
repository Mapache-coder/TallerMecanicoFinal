@model TallerMecanicoFinal.Controllers.AppointmentFormViewModel

<form asp-controller="Appointments" asp-action="@(Model.Id.HasValue ? "Edit" : "Create")" method="post" class="appointment-form">
    @Html.AntiForgeryToken()
    @if (Model.Id.HasValue)
    {
        <input asp-for="Id" type="hidden" />
    }

    <div class="modal-header bg-soft border-0">
        <div>
            <h5 class="modal-title mb-1">@(Model.Id.HasValue ? "Editar cita" : "Nueva cita")</h5>
            <p class="text-muted mb-0 small">Todos los minutos se guardan en :00.</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <div class="modal-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label asp-for="Plate" class="form-label"></label>
                <input asp-for="Plate" class="form-control" />
                <span asp-validation-for="Plate" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="Brand" class="form-label"></label>
                <input asp-for="Brand" class="form-control" />
                <span asp-validation-for="Brand" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="Model" class="form-label"></label>
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="OwnerDocument" class="form-label"></label>
                <input asp-for="OwnerDocument" class="form-control" />
                <span asp-validation-for="OwnerDocument" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="OwnerName" class="form-label"></label>
                <input asp-for="OwnerName" class="form-control" />
                <span asp-validation-for="OwnerName" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="OwnerPhone" class="form-label"></label>
                <input asp-for="OwnerPhone" class="form-control" />
                <span asp-validation-for="OwnerPhone" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Mileage" class="form-label"></label>
                <input asp-for="Mileage" class="form-control" />
                <span asp-validation-for="Mileage" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="ScheduledAt" class="form-label"></label>
                <input asp-for="ScheduledAt" type="datetime-local" class="form-control" />
                <span asp-validation-for="ScheduledAt" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="modal-footer border-0 bg-soft">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-accent">Guardar</button>
    </div>
</form>