@model TallerMecanicoFinal.Models.PlateHistoryPageViewModel
@{
    ViewData["Title"] = "Historial por placa";
}

<div class="appointment-page">
    <div class="card border-0 shadow-sm appointment-hero mb-4">
        <div class="card-body p-4 p-md-5">
            <p class="text-uppercase text-accent fw-semibold mb-1">Administrador</p>
            <h1 class="h3 mb-2">Historial por placa</h1>
            <p class="text-muted mb-0">Solo se muestran órdenes Completadas y citas futuras Programadas. Las canceladas no existen en historial.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form asp-controller="Reports" asp-action="History" method="get" class="row g-3 align-items-end">
                <div class="col-12 col-md-8">
                    <label for="plate" class="form-label">Placa</label>
                    <input id="plate" name="plate" value="@Model.SearchPlate" class="form-control" placeholder="Ej. ABC123" />
                </div>
                <div class="col-12 col-md-4 d-grid">
                    <button type="submit" class="btn btn-accent">Buscar</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.HasSearch && Model.Results.Count == 0)
    {
        <div class="alert alert-info">No se encontraron órdenes Completadas ni citas futuras Programadas para esa placa.</div>
    }

    <div class="row g-4">
        @foreach (var item in Model.Results)
        {
            <div class="col-12 col-lg-6 col-xxl-4">
                <div class="card border-0 shadow-sm appointment-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <div class="text-uppercase small text-muted">@item.Plate</div>
                                <h2 class="h5 mb-1">@item.OwnerName</h2>
                                <div class="text-muted">@item.Brand @item.Model</div>
                            </div>
                            <span class="badge rounded-pill text-bg-light appointment-status">@item.StatusLabel</span>
                        </div>
                        <dl class="row small mb-3">
                            <dt class="col-5 text-muted">Fecha</dt>
                            <dd class="col-7">@item.ScheduledAt.ToString("dd/MM/yyyy HH:mm")</dd>
                            <dt class="col-5 text-muted">Mecánico</dt>
                            <dd class="col-7">@item.MechanicName</dd>
                            @if (!string.IsNullOrWhiteSpace(item.Diagnosis))
                            {
                                <dt class="col-5 text-muted">Diagnóstico</dt>
                                <dd class="col-7">@item.Diagnosis</dd>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Solution))
                            {
                                <dt class="col-5 text-muted">Solución</dt>
                                <dd class="col-7">@item.Solution</dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>
        }
    </div>
</div>